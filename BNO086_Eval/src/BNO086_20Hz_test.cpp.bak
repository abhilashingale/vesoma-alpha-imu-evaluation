#include <Wire.h>
#include "SparkFun_BNO080_Arduino_Library.h" 

BNO080 imu; 

#define BNO_RST 17
#define BNO_INT 16 // We will define this but not use it in begin() for now
#define BNO_ADDR 0x4B 

void setup() {
  // Switch to a more standard baud rate for the Serial Monitor
  Serial.begin(115200); 
  
  while (!Serial) 
    delay(10);
  
  Serial.println(F("\n--- BNO080 Human-Readable Debug ---"));

  // 1. Manual Hardware Reset
  pinMode(BNO_RST, OUTPUT);
  digitalWrite(BNO_RST, LOW);
  delay(100);
  digitalWrite(BNO_RST, HIGH);
  delay(600); 

  Wire.begin();
  Wire.setClock(100000); 

  // 2. Initialize WITHOUT the interrupt pin in begin()

  Serial.print(F("Connecting to BNO080 at 0x4B... "));
  if (imu.begin(BNO_ADDR, Wire) == false) {
    Serial.println(F("FAILED. Check I2C wiring and address."));
    while (1); 
  }
  Serial.println(F("SUCCESS!"));

  // 3. Enable Reports
  imu.enableRotationVector(50); // 50ms (20Hz) is easier to read by eye
  imu.enableAccelerometer(50);
  imu.enableGyro(50);

  Serial.println(F("Timestamp(ms), Real, I, J, K, AccelX, AccelY, AccelZ"));
}

void loop() {
  // Check for data manually (Polling)
  if (imu.dataAvailable()) {
    // 1. Print Timestamp
    Serial.print(millis());
    Serial.print(F(", "));

    // 2. Print Quaternions
    Serial.print(imu.getQuatReal(), 3); Serial.print(F(", "));
    Serial.print(imu.getQuatI(), 3);    Serial.print(F(", "));
    Serial.print(imu.getQuatJ(), 3);    Serial.print(F(", "));
    Serial.print(imu.getQuatK(), 3);    Serial.print(F(", "));

    // 3. Print Accelerometer
    Serial.print(imu.getAccelX(), 2); Serial.print(F(", "));
    Serial.print(imu.getAccelY(), 2); Serial.print(F(", "));
    Serial.println(imu.getAccelZ(), 2); // println ends the line
  }
}